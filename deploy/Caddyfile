# Caddy reverse proxy for Seald API.
#
# Auto-HTTPS via Let's Encrypt (ACME) using the CADDY_DOMAIN env var. Caddy
# handles certificate issuance + renewal with zero config beyond the domain.
#
# Forwarded-For:
#   Caddy sets X-Forwarded-For + X-Real-IP automatically. The API honors
#   X-Forwarded-For for audit-log IP capture (see extractClientIp in
#   signing.controller.ts); anything else (host/proto headers) is
#   handled by Caddy's reverse_proxy defaults.

{$CADDY_DOMAIN} {
	encode zstd gzip

	# Block the internal cron surface from hitting the public edge — it's
	# only supposed to be called loopback-to-loopback on the host.
	@internal path /internal/*
	handle @internal {
		respond 404
	}

	# Block Prometheus metrics from the public edge. METRICS_SECRET
	# gates them at the app layer too, but defense-in-depth.
	@metrics path /metrics
	handle @metrics {
		respond 404
	}

	reverse_proxy api:3000 {
		header_up Host {host}
		# Don't forward the container's upstream hop header; Caddy rewrites X-F-F.
		header_up -X-Forwarded-Host
	}

	log {
		output stdout
		format console
	}
}

# ---------------------------------------------------------------------
# Static SPA frontend. The GitHub Actions `deploy-web.yml` workflow
# builds `apps/web` with Vite and drops the result into
# `/opt/seald/apps/web/dist/` on the host; this block mounts that
# directory read-only and serves it with an SPA fallback (react-router
# needs every unmatched path to hit `/index.html`).
#
# Long-cache static assets, no-cache the HTML shell so new deploys are
# picked up on next navigation.
# ---------------------------------------------------------------------
{$WEB_DOMAIN} {
	encode zstd gzip
	root * /srv/web

	# Never cache the entry shell so clients pick up new asset hashes
	# on the next navigation without a hard refresh.
	@html path / /index.html
	header @html Cache-Control "no-cache, no-store, must-revalidate"

	# Vite emits every JS/CSS/image with a content hash in the
	# filename; those are safe to cache aggressively.
	@hashedAssets path_regexp ^/assets/
	header @hashedAssets Cache-Control "public, max-age=31536000, immutable"

	# SPA routing: any path that isn't an existing file falls through
	# to /index.html so react-router can hydrate.
	try_files {path} /index.html
	file_server

	log {
		output stdout
		format console
	}
}
