---
// Footer.astro — brand mark, three short link columns, legal line.
// Plain text links keep the footer accessible and low-noise.

import Logo from './Logo.astro';

const SPA_URL = 'https://seald.nromomentum.com';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <Logo />
      <p class="footer-tagline">A quieter way to sign.</p>
    </div>

    <nav class="footer-cols" aria-label="Footer">
      <div class="footer-col">
        <h5 class="footer-h">Product</h5>
        <ul role="list">
          <li><a href={`${SPA_URL}/signup`}>Sign up</a></li>
          <li><a href={`${SPA_URL}/login`}>Sign in</a></li>
          <li><a href="#how-it-works">How it works</a></li>
          <li><a href="#features">Features</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5 class="footer-h">Trust</h5>
        <ul role="list">
          <li><a href="#trust">Compliance</a></li>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5 class="footer-h">Contact</h5>
        <ul role="list">
          <li><a href="mailto:hello@seald.nromomentum.com">hello@seald.nromomentum.com</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="container footer-bottom">
    <p class="footer-legal">
      &copy; {year} Sealed. Crafted with care for the contracts you actually keep.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--paper);
    border-top: 1px solid var(--border-1);
    padding-block: var(--sp-16) var(--sp-8);
    color: var(--fg-3);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-12);
    margin-bottom: var(--sp-12);
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 2fr);
      gap: var(--sp-16);
    }
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--fg-3);
    margin-top: var(--sp-3);
    font-size: var(--fs-body);
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-8);
  }
  @media (min-width: 640px) {
    .footer-cols { grid-template-columns: repeat(3, 1fr); }
  }

  .footer-h {
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--fg-1);
    margin-bottom: var(--sp-3);
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--sp-2);
  }
  .footer-col a {
    color: var(--fg-2);
    font-size: var(--fs-body-sm);
  }
  .footer-col a:hover { color: var(--fg-1); text-decoration: underline; }

  .footer-bottom {
    border-top: 1px solid var(--border-1);
    padding-top: var(--sp-6);
  }
  .footer-legal {
    font-size: var(--fs-caption);
    color: var(--fg-3);
    margin: 0;
  }
</style>
