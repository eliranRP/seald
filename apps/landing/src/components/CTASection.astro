---
// CTASection.astro — secondary signup nudge near the bottom of the page.

const SPA_URL = 'https://seald.nromomentum.com';
---
<section class="section cta-section">
  <div class="container">
    <div class="cta-card">
      <div class="cta-copy">
        <h2 class="cta-h2">
          Ready to put your <span class="cta-name">name</span> to it?
        </h2>
        <p class="cta-sub">
          Free to sign your first ten documents. No card. No banner ads.
          No upsells in your inbox.
        </p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-primary btn-lg" href={`${SPA_URL}/signup`}>
          Create your account
        </a>
        <a class="btn btn-ghost" href={`${SPA_URL}/login`}>
          I already have one
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section { background: var(--bg-app); }
  .cta-card {
    background: var(--paper);
    border: 1px solid var(--border-1);
    border-radius: var(--r-2xl);
    padding: clamp(var(--sp-8), 5vw, var(--sp-16));
    display: grid;
    gap: var(--sp-8);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .cta-card {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--sp-12);
    }
  }

  .cta-h2 {
    font-size: clamp(28px, 4vw, var(--fs-h2));
    margin-bottom: var(--sp-3);
  }
  .cta-name { font-style: italic; }
  .cta-sub { color: var(--fg-2); max-width: 56ch; }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
  }
</style>
