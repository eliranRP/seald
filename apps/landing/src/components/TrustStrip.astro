---
// TrustStrip.astro — compliance + technical trust claims, presented
// quietly. No logos we can't legally use; copy carries the weight.

const claims = [
  {
    label: 'PAdES-LTV',
    body:
      'Long-Term Validation profile compliant with EU eIDAS and ISO 32000-2.',
  },
  {
    label: 'RFC 3161',
    body:
      'Independent timestamp authority on every seal — verifiable for years.',
  },
  {
    label: 'Encrypted at rest',
    body:
      'AES-256 envelope encryption on every page, every revision, every audit log.',
  },
  {
    label: 'Audit trail',
    body:
      "Last page of the signed PDF carries a complete, tamper-evident event log.",
  },
];
---
<section class="section trust" id="trust">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow">Trust by construction</p>
      <h2>Built to outlast the contract.</h2>
      <p class="lede">
        Sealed isn't a wrapper around a wet signature — it's a cryptographic
        seal a regulator would recognise.
      </p>
    </header>

    <dl class="claims">
      {claims.map((claim) => (
        <div class="claim">
          <dt class="claim-label mono">{claim.label}</dt>
          <dd class="claim-body">{claim.body}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .trust { border-top: 1px solid var(--border-1); }
  .section-head {
    max-width: 720px;
    margin-bottom: var(--sp-12);
    display: grid;
    gap: var(--sp-3);
  }
  .lede { font-size: var(--fs-body-lg); color: var(--fg-2); }

  .claims {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--border-1);
  }
  @media (min-width: 768px) {
    .claims { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .claims { grid-template-columns: repeat(4, 1fr); }
  }

  .claim {
    padding: var(--sp-6) 0;
    border-bottom: 1px solid var(--border-1);
    margin-right: 0;
    display: grid;
    gap: var(--sp-2);
  }
  @media (min-width: 768px) {
    .claim { padding-right: var(--sp-6); border-right: 1px solid var(--border-1); }
    .claim:last-of-type { border-right: none; }
    .claim:nth-last-of-type(-n+2) { border-bottom: none; }
  }
  @media (min-width: 1024px) {
    .claim:nth-last-of-type(-n+4) { border-bottom: none; }
  }

  .claim-label {
    font-size: var(--fs-caption);
    color: var(--accent);
    letter-spacing: var(--tracking-wide);
    text-transform: none;
  }
  .claim-body {
    margin: 0;
    color: var(--fg-2);
  }
</style>
