---
// Header.astro — sticky top nav with logo + sign-in CTA.
//
// Sealed convention: 56px tall, border-bottom, no shadow. When the page
// scrolls underneath, a subtle backdrop blur kicks in (see :global rule).

import Logo from './Logo.astro';

const SPA_URL = 'https://seald.nromomentum.com';
---
<header class="header">
  <nav class="container nav" aria-label="Primary">
    <Logo />

    <ul class="nav-links" role="list">
      <li><a href="#how-it-works">How it works</a></li>
      <li><a href="#features">Features</a></li>
      <li><a href="#trust">Trust</a></li>
    </ul>

    <div class="nav-actions">
      <a class="btn btn-ghost nav-signin" href={`${SPA_URL}/login`}>Sign in</a>
      <a class="btn btn-primary" href={`${SPA_URL}/signup`}>Get started</a>
    </div>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border-1);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    height: 56px;
  }
  .nav-links {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--sp-8);
  }
  .nav-links a {
    color: var(--fg-2);
    font-size: var(--fs-body-sm);
    font-weight: 500;
  }
  .nav-links a:hover { color: var(--fg-1); text-decoration: none; }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .nav-signin { display: none; }

  @media (min-width: 768px) {
    .nav-links { display: flex; }
    .nav-signin { display: inline-flex; }
  }
</style>
