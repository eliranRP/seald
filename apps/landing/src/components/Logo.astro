---
// Logo.astro — inline SVG mirroring Design-Guide/project/assets/logo.svg.
// Inlining keeps the mark in the critical path so first paint shows the
// brand instantly, and lets it inherit `currentColor` if needed later.

interface Props {
  withWordmark?: boolean;
  height?: number;
}

const { withWordmark = true, height = 32 } = Astro.props;
const width = withWordmark ? height * 4 : height; // ~4:1 lockup
---
<a href="/" aria-label="Sealed home" class="logo-link">
  {withWordmark ? (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 160 40"
      width={width}
      height={height}
      role="img"
      aria-label="Sealed"
    >
      <g transform="translate(4, 6)">
        <path
          d="M2 24 C 6 22, 10 16, 14 14 L 22 6 L 26 10 L 18 18 C 16 22, 10 26, 4 28 Z"
          fill="#4F46E5"
        />
        <path
          d="M22 6 L 24 4 C 25 3, 26.5 3, 27.5 4 L 28 4.5 C 29 5.5, 29 7, 28 8 L 26 10 Z"
          fill="#312E81"
        />
        <path
          d="M2 30 C 8 28, 18 28, 28 30"
          stroke="#4F46E5"
          stroke-width="1.5"
          stroke-linecap="round"
          fill="none"
        />
      </g>
      <text
        x="42"
        y="27"
        font-family="'Source Serif 4', Georgia, serif"
        font-size="22"
        font-weight="500"
        fill="#0B1220"
        letter-spacing="-0.01em"
      >Sealed</text>
    </svg>
  ) : (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 32 32"
      width={height}
      height={height}
      role="img"
      aria-label="Sealed"
    >
      <g transform="translate(0, 1)">
        <path
          d="M2 24 C 6 22, 10 16, 14 14 L 22 6 L 26 10 L 18 18 C 16 22, 10 26, 4 28 Z"
          fill="#4F46E5"
        />
        <path
          d="M22 6 L 24 4 C 25 3, 26.5 3, 27.5 4 L 28 4.5 C 29 5.5, 29 7, 28 8 L 26 10 Z"
          fill="#312E81"
        />
      </g>
    </svg>
  )}
</a>

<style>
  .logo-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    border-radius: var(--r-sm);
  }
  .logo-link:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }
</style>
