---
// HowItWorks.astro — three-step product walkthrough.
// Designed as numbered cards on a horizontal rail (desktop) or stacked
// list (mobile). Mirrors the README's "Upload → Place → Sign" rhythm.

const steps = [
  {
    n: '01',
    title: 'Drop a PDF',
    body:
      "Upload from your computer or paste a link. Up to 25 MB. We don't keep anything we don't need.",
  },
  {
    n: '02',
    title: 'Place fields',
    body:
      'Drag a signature, date, or initial onto the page. Add signers in any order. Save the layout for next time.',
  },
  {
    n: '03',
    title: 'Send for signature',
    body:
      "Each signer gets a calm email with a single link. We'll let you know the moment everyone's done.",
  },
  {
    n: '04',
    title: 'Sealed for keeps',
    body:
      'The signed copy lands back in your inbox with a PAdES seal, an RFC 3161 timestamp, and an audit trail on the last page.',
  },
];
---
<section class="section how" id="how-it-works">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow">How it works</p>
      <h2>Four steps. None of them annoying.</h2>
      <p class="lede">
        Sealed gets out of your way at every step — the document is the
        product, not the chrome around it.
      </p>
    </header>

    <ol class="steps" role="list">
      {steps.map((step) => (
        <li class="card step">
          <span class="step-n mono">{step.n}</span>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-body">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how { background: var(--bg-app); }
  .section-head {
    max-width: 720px;
    margin-bottom: var(--sp-12);
    display: grid;
    gap: var(--sp-3);
  }
  .lede { font-size: var(--fs-body-lg); color: var(--fg-2); }

  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @media (min-width: 640px) {
    .steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .steps { grid-template-columns: repeat(4, 1fr); gap: var(--sp-4); }
  }

  .step {
    display: grid;
    gap: var(--sp-3);
    align-content: start;
  }
  .step-n {
    color: var(--accent);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
  }
  .step-title { font-size: var(--fs-h5); }
  .step-body { color: var(--fg-2); font-size: var(--fs-body-sm); }
</style>
