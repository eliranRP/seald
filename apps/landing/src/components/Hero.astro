---
// Hero.astro — primary brand moment.
//
// Layout:
//   - Eyebrow (small all-caps)
//   - Display H1 with the script flourish under "name" (per design-guide)
//   - Subhead
//   - Primary + secondary CTAs
//   - Document-preview illustration on the right (decorative SVG)
//
// The script underline beneath "name" is the only flourish the brand
// allows — see Design-Guide/project/README.md "Signature motif".

const SPA_URL = 'https://seald.nromomentum.com';
---
<section class="hero" id="main">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Document signing, sealed</p>

      <h1 class="hero-h1">
        Put your <span class="hero-name">
          name
          <svg
            class="hero-flourish"
            viewBox="0 0 120 16"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M3 11 C 22 4, 50 4, 75 8 S 110 14, 117 7"
              stroke="#4F46E5"
              stroke-width="2"
              stroke-linecap="round"
              fill="none"
            />
          </svg>
        </span> to it.
      </h1>

      <p class="hero-sub">
        Sealed is a quieter way to sign, send, and store documents —
        built for the contracts you actually care about.
      </p>

      <div class="hero-ctas">
        <a class="btn btn-primary btn-lg" href={`${SPA_URL}/signup`}>
          Start signing free
        </a>
        <a class="btn btn-secondary btn-lg" href="#how-it-works">
          See how it works
        </a>
      </div>

      <p class="hero-meta">
        <span class="dot" aria-hidden="true"></span>
        EU-grade PAdES seals · RFC 3161 timestamps · audit trail on every page
      </p>
    </div>

    <div class="hero-art" aria-hidden="true">
      <!-- A single, calm document preview — paper, hairline border,
           subtle shadow, with a script signature stroked along the
           bottom-right. No people, no photography (per brand). -->
      <div class="paper">
        <div class="paper-head">
          <span class="paper-label">Master services agreement</span>
          <span class="paper-id mono">DOC-2026-04-1042</span>
        </div>
        <div class="paper-line w-90"></div>
        <div class="paper-line w-72"></div>
        <div class="paper-line w-85"></div>
        <div class="paper-line w-60"></div>
        <div class="paper-line w-78"></div>
        <div class="paper-spacer"></div>
        <div class="paper-line w-90"></div>
        <div class="paper-line w-65"></div>
        <div class="paper-spacer"></div>
        <div class="paper-sig">
          <span class="script paper-sig-name">Eliran Azulay</span>
          <span class="paper-sig-rule"></span>
          <span class="mono paper-sig-meta">Signed Apr 25, 2026 · 14:02 UTC</span>
        </div>
      </div>

      <!-- Status pill floating over the document -->
      <span class="seal-pill">
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
          <path
            d="M20 6 9 17l-5-5"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        </svg>
        Sealed
      </span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: var(--sp-20);
    padding-bottom: var(--sp-24);
    background:
      linear-gradient(180deg, var(--ink-50) 0%, var(--paper) 80%);
    overflow: hidden;
  }
  @media (max-width: 767px) {
    .hero { padding-top: var(--sp-12); padding-bottom: var(--sp-16); }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-12);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      gap: var(--sp-20);
    }
  }

  .hero-h1 {
    font-size: clamp(40px, 7vw, var(--fs-display));
    line-height: var(--lh-tight);
    margin-top: var(--sp-4);
    margin-bottom: var(--sp-6);
    color: var(--fg-1);
  }
  .hero-name {
    position: relative;
    font-style: italic;
    color: var(--fg-1);
  }
  .hero-flourish {
    position: absolute;
    left: -2%;
    bottom: -0.35em;
    width: 104%;
    height: 0.4em;
    pointer-events: none;
  }

  .hero-sub {
    font-size: var(--fs-body-lg);
    color: var(--fg-2);
    max-width: 56ch;
    margin-bottom: var(--sp-8);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }

  .hero-meta {
    font-size: var(--fs-body-sm);
    color: var(--fg-3);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--success-500);
    flex: 0 0 auto;
  }

  /* Document preview ----------------------------------------- */

  .hero-art {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .paper {
    width: 100%;
    max-width: 460px;
    background: var(--paper);
    border-radius: var(--r-2xl);
    box-shadow: var(--shadow-paper);
    padding: var(--sp-8);
    transform: rotate(-1.2deg);
  }
  @media (min-width: 1024px) {
    .paper { transform: rotate(-2deg); }
  }

  .paper-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--border-1);
  }
  .paper-label {
    font-family: var(--font-serif);
    font-size: var(--fs-h5);
    color: var(--fg-1);
    font-weight: 500;
  }
  .paper-id {
    font-size: var(--fs-micro);
    color: var(--fg-3);
    letter-spacing: var(--tracking-wide);
  }

  .paper-line {
    height: 8px;
    background: var(--ink-150);
    border-radius: var(--r-pill);
    margin-block: var(--sp-3);
  }
  .w-60 { width: 60%; }
  .w-65 { width: 65%; }
  .w-72 { width: 72%; }
  .w-78 { width: 78%; }
  .w-85 { width: 85%; }
  .w-90 { width: 90%; }
  .paper-spacer { height: var(--sp-4); }

  .paper-sig {
    margin-top: var(--sp-8);
    display: grid;
    gap: var(--sp-2);
  }
  .paper-sig-name {
    font-size: 36px;
    line-height: 1;
    color: var(--ink-900);
  }
  .paper-sig-rule {
    height: 1px;
    background: var(--ink-300);
    width: 60%;
  }
  .paper-sig-meta {
    font-size: var(--fs-micro);
    color: var(--fg-3);
    letter-spacing: var(--tracking-wide);
  }

  .seal-pill {
    position: absolute;
    top: var(--sp-6);
    right: var(--sp-2);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 6px 12px;
    border-radius: var(--r-pill);
    background: var(--success-50);
    color: var(--success-700);
    font-size: var(--fs-caption);
    font-weight: 600;
    border: 1px solid rgba(16, 185, 129, 0.25);
  }
  @media (min-width: 1024px) {
    .seal-pill { right: -8px; }
  }
</style>
