{
  "name": "web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "bdd:gen": "bddgen",
    "bdd": "bddgen && playwright test",
    "bdd:smoke": "bddgen && playwright test --grep @smoke",
    "bdd:full": "bddgen && playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes --build-script-name=build-storybook",
    "chromatic:ci": "chromatic --exit-zero-on-changes --build-script-name=build-storybook --auto-accept-changes=main"
  },
  "dependencies": {
    "@sentry/react": "^10",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.7",
    "axios": "^1.15.2",
    "lucide-react": "1.14.0",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.14.2",
    "shared": "workspace:*",
    "styled-components": "6.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@playwright/test": "^1",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "20.16.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "3.11.0",
    "@vitest/coverage-v8": "4.1.5",
    "chromatic": "^16",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.0",
    "eslint-plugin-react": "7.37.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "^15",
    "jsdom": "25.0.1",
    "playwright-bdd": "^8",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "10.3.5",
    "typescript": "5.6.3",
    "typescript-eslint": "^8",
    "vite": "7.3.2",
    "vitest": "4.1.5",
    "vitest-axe": "0.1.0",
    "eslint-plugin-storybook": "10.3.5",
    "@storybook/addon-docs": "10.3.5"
  }
}
