{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "description": "Seald backend API",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config test/jest-e2e.json",
    "test:mutation": "stryker run",
    "storage:init": "node scripts/ensure-storage-bucket.mjs",
    "smoke:upload": "node scripts/smoke-upload.mjs",
    "seed:signer": "ts-node --transpile-only scripts/seed-signer.ts",
    "flush:emails": "ts-node --transpile-only scripts/flush-emails.ts",
    "kms:gen-cert": "ts-node --transpile-only scripts/generate-kms-binding-cert.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1042.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@react-pdf/renderer": "^4.5.1",
    "@signpdf/placeholder-plain": "^3",
    "@signpdf/signer-p12": "^3",
    "@signpdf/signpdf": "^3",
    "@signpdf/utils": "^3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie": "^1",
    "express": "^4.21.0",
    "helmet": "^7.2.0",
    "jose": "^6.2.3",
    "kysely": "^0.28.17",
    "multer": "^2.1.1",
    "nanoid": "^5",
    "node-forge": "1.4.0",
    "pdf-lib": "^1.17",
    "pg": "^8.20.0",
    "pino": "^9",
    "prom-client": "^15",
    "qrcode": "^1.5",
    "rate-limiter-flexible": "^11",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "shared": "workspace:*",
    "sharp": "^0.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.21",
    "@stryker-mutator/core": "^8.6.0",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@types/cookie": "^1.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "20.16.10",
    "@types/node-forge": "^1.3",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "canvas": "^3.2.3",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "jest": "^30.4.2",
    "pdfjs-dist": "^4.2.67",
    "pg-mem": "^3.0.14",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.6.3"
  }
}
