.superpowers/

# Signing secrets — dev .p12 certs live here; production uses the SSL.com AATL
# cloud HSM provider, which never puts private keys on disk.
# Never commit anything from secrets/. Rotate any key that ever lands in git.
apps/*/secrets/
secrets/

# Dev-only mail output — LoggingEmailSender writes rendered HTML/txt here.
# Open in a browser to preview transactional email without sending real mail.
.seald-mail/
apps/*/.seald-mail/
