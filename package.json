{
  "name": "seald-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:landing": "pnpm --filter landing dev",
    "build": "pnpm -r build",
    "build:landing": "pnpm --filter landing build",
    "lint": "pnpm -r lint",
    "lint:workflows": "actionlint",
    "lint:gherkin": "gherkin-lint 'apps/web/e2e/features/**/*.feature'",
    "lint:spelling": "cspell lint --no-progress --no-must-find-files --no-gitignore '.github/workflows/**/*.yml' 'apps/web/e2e/features/**/*.feature' 'apps/web/src/**/*.{ts,tsx}' 'apps/api/src/**/*.ts' 'packages/shared/src/**/*.ts'",
    "lint:all": "pnpm lint:workflows && pnpm lint:gherkin && pnpm lint:spelling && pnpm -r lint",
    "typecheck": "tsc -b",
    "typecheck:recursive": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "cspell": "^10",
    "gherkin-lint": "^4.2.4",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "typescript": "5.6.3"
  },
  "pnpm": {
    "overrides": {
      "crypto-js@<4.2.0": ">=4.2.0",
      "tar@<7.5.11": ">=7.5.11",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@<2.8.3": ">=2.8.3",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "postcss@<8.5.10": ">=8.5.10",
      "file-type@>=13.0.0 <21.3.2": ">=21.3.2",
      "esbuild@<0.25.0": ">=0.25.0",
      "@types/react": "^19",
      "@types/react-dom": "^19"
    }
  }
}
